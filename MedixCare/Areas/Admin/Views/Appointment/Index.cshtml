@model MedixCare.ViewModels.AppointementVM
@using MedixCare.Models

@{
    ViewData["Title"] = "Appointments Management";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-calendar-check me-2"></i>Appointments
            </h2>
            <p class="text-muted mb-0">Manage and view patient appointments, schedules, and statuses.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> New Appointment
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="Index">
                <div class="row g-2 align-items-center justify-content-end">
                    <div class="col-12 col-md-8 col-lg-6">
                        <div class="input-group">
                            <input type="text"
                                   name="query"
                                   value="@Model.query"
                                   class="form-control bg-light border-0 py-2 ps-3"
                                   placeholder="Search by Patient or Doctor name..." />
                            <button type="submit" class="btn btn-primary px-4 fw-semibold">Search</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.query))
                    {
                        <div class="col-auto">
                            <a asp-action="Index" class="btn btn-light text-secondary border-0 fw-semibold">
                                <i class="bi bi-x-lg me-1"></i> Clear Search
                            </a>
                        </div>
                    }
                </div>
            </form>
        </div>
    </div>


    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (Model.Appointments != null && Model.Appointments.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-4">ID</th>
                                <th scope="col">Patient Name</th>
                                <th scope="col">Doctor Name</th>
                                <th scope="col">Appointment Date</th>
                                <th scope="col">Booking Channel</th>
                                <th scope="col">Visit Type</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Appointments)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-muted">#@item.Id</td>
                                    <td>
                                        <div class="fw-bold text-dark">
                                            @(item.Patient?.Name ?? "N/A")
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-secondary fw-semibold">
                                            <i class="bi bi-person-badge me-1"></i>
                                            Dr. @(item.Doctor?.Name ?? "N/A")
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <i class="bi bi-clock me-1 text-muted"></i>
                                            @item.AppointmentDate.ToString("MMM dd, yyyy - hh:mm tt")
                                        </div>
                                    </td>
                                    <td>
                                        @switch (item.BookingChannel)
                                        {
                                            case BookingChannel.Phone:
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill">
                                                    <i class="bi bi-telephone-fill me-1"></i> Phone
                                                </span>
                                                break;
                                            case BookingChannel.Online:
                                                <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill">
                                                    <i class="bi bi-globe me-1"></i> Online
                                                </span>
                                                break;
                                            case BookingChannel.WalkIn:
                                                <span class="badge bg-light text-dark border rounded-pill">
                                                    <i class="bi bi-person-walk me-1"></i> Walk-In
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (item.VisitType == VisitType.Examination)
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                                Examination
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                                Follow-Up
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case AppointmentStatus.Scheduled:
                                                <span class="badge bg-primary">Scheduled</span>
                                                break;
                                            case AppointmentStatus.Completed:
                                                <span class="badge bg-success">Completed</span>
                                                break;
                                            case AppointmentStatus.Cancelled:
                                                <span class="badge bg-danger">Cancelled</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

          
                @if (Model.TotalPages > 1)
                {
                    <div class="card-footer bg-white border-0 py-3">
                        <nav aria-label="Appointments page navigation">
                            <ul class="pagination justify-content-center mb-0">
                       
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@(Model.CurrentPage - 1)"
                                       asp-route-query="@Model.query">
                                        <i class="bi bi-chevron-left me-1"></i> Previous
                                    </a>
                                </li>

                
                                @for (int i = 1; i <= (int)Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link"
                                           asp-action="Index"
                                           asp-route-page="@i"
                                           asp-route-query="@Model.query">@i</a>
                                    </li>
                                }

                     
                                <li class="page-item @(Model.CurrentPage == (int)Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@(Model.CurrentPage + 1)"
                                       asp-route-query="@Model.query">
                                        Next <i class="bi bi-chevron-right ms-1"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x display-1 text-muted mb-3"></i>
                    <h4 class="text-secondary fw-semibold">No Appointments Found</h4>
                    <p class="text-muted">There are no records matching your search criteria.</p>
                    @if (!string.IsNullOrWhiteSpace(Model.query))
                    {
                        <a asp-action="Index" class="btn btn-outline-primary btn-sm mt-2">Reset Search</a>
                    }
                </div>
            }
        </div>
    </div>
</div>
@model UpdateAppointmentVM

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-info text-white py-2">
                    <h6 class="mb-0">
                        <i class="bi bi-clock-history"></i> Working Hours for: @Model.DoctorName
                    </h6>
                </div>
                <div class="card-body">
                    @if (Model.DoctorSchedules != null && Model.DoctorSchedules.Any())
                    {
                        <div class="row">
                            @foreach (var schedule in Model.DoctorSchedules)
                            {
                                <div class="col-md-6 mb-2">
                                    <div class="p-2 border rounded bg-light d-flex justify-content-between">
                                        <span class="fw-bold text-dark">@schedule.DayOfWeek</span>
                                        <span class="text-primary">
                                            @schedule.StartTime To @schedule.EndTime
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 p-2">
                            <i class="bi bi-exclamation-triangle"></i> No schedule defined for this doctor.
                        </div>
                    }
                </div>
            </div>

      
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Staff Panel: Update Appointment</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" asp-route-id="@Model.Id" asp-route-doctorId="@Model.DoctorId" asp-route-visitType="@Model.VisitType" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                        <div class="mb-3">
                            <label asp-for="PatientId" class="form-label fw-bold">Patient:</label>
                            <select asp-for="PatientId" class="form-select form-select-lg">
                                <option value="">-- Choose Patient --</option>
                                @if (Model.PatientsList != null)
                                {
                                    foreach (var patient in Model.PatientsList)
                                    {
                                        <option value="@patient.Id">@patient.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="PatientId" class="text-danger small"></span>
                        </div>

                    
                        <div class="mb-4">
                            <label asp-for="AppointmentDate" class="form-label fw-bold">Appointment Date:</label>
                            <input asp-for="AppointmentDate"
                                   type="date"
                                   value="@Model.AppointmentDate.ToString("yyyy-MM-dd")"
                                   class="form-control form-control-lg" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-bold text-dark">
                                <i class="bi bi-tag-fill text-info me-1"></i> Appointment Status:
                            </label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<AppointmentStatus>()" class="form-select form-select-lg border-2">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
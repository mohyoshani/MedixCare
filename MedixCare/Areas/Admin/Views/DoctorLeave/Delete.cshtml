@model DoctorLeave

@{
    ViewData["Title"] = "Delete Doctor Leave";
}

<h1>Delete Doctor Leave</h1>

<h3>Are you sure you want to delete this?</h3>
<dl class="row">
    <dt class="col-sm-2">Doctor</dt>
    <dd class="col-sm-10">@Model.Doctor?.Name</dd>
    <dt class="col-sm-2">Reason</dt>
    <dd class="col-sm-10">@Model.Reason</dd>
    <dt class="col-sm-2">Leave From</dt>
    <dd class="col-sm-10">@Model.LeaveFrom.ToShortDateString()</dd>
    <dt class="col-sm-2">Leave To</dt>
    <dd class="col-sm-10">@Model.LeaveTo.ToShortDateString()</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

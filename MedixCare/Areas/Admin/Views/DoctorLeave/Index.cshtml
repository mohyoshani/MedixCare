@model IEnumerable<DoctorLeave>

@{
    ViewData["Title"] = "Doctor Leaves";
}

<h1>Doctor Leaves</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Doctor</th>
            <th>Reason</th>
            <th>Leave From</th>
            <th>Leave To</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Doctor?.Name</td>
            <td>@item.Reason</td>
            <td>@item.LeaveFrom.ToShortDateString()</td>
            <td>@item.LeaveTo.ToShortDateString()</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@model DoctorSchedule

@{
    ViewData["Title"] = "Delete Doctor Schedule";
}

<h1>Delete Doctor Schedule</h1>

<h3>Are you sure you want to delete this?</h3>
<dl class="row">
    <dt class="col-sm-2">Doctor</dt>
    <dd class="col-sm-10">@Model.Doctor?.Name</dd>
    <dt class="col-sm-2">Day Of Week</dt>
    <dd class="col-sm-10">@Model.DayOfWeek</dd>
    <dt class="col-sm-2">Start Time</dt>
    <dd class="col-sm-10">@Model.StartTime</dd>
    <dt class="col-sm-2">End Time</dt>
    <dd class="col-sm-10">@Model.EndTime</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

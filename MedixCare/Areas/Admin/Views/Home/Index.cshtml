@model AdminDashboardVM

<div class="container-fluid py-4 bg-light min-vh-100">


    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">MedixCare Admin Dashboard</h2>
            <p class="text-muted small mb-0">Welcome back! Here's what's happening in your clinic today.</p>
        </div>
        <span class="badge bg-white text-dark shadow-sm border px-3 py-2 fw-semibold">
            <i class="bi bi-calendar3 text-primary me-2"></i>@DateTime.Now.ToString("dd MMMM, yyyy")
        </span>
    </div>


    <div class="row g-3 mb-4">

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-white">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary-subtle text-primary p-3 rounded-3 me-3">
                        <i class="bi bi-calendar-check fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-medium">Today's Visits</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TodayAppointmentsCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body d-flex align-items-center">
         
                    <div class="me-3 text-warning" style="font-size: 1.8rem;">
                        <i class="fas fa-flask"></i>
                    </div>

                    <div>
                        <span class="text-muted small d-block mb-1 fw-medium">Pending Lab Tests</span>
                        <h3 class="fw-bold text-dark mb-0">@Model.PendingTestsCount</h3>
                    </div>
                </div>
            </div>
        </div>
      
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-white">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success-subtle text-success p-3 rounded-3 me-3">
                        <i class="bi bi-people fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-medium">Total Patients</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TotalPatientsCount</h3>
                    </div>
                </div>
            </div>
        </div>

      
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 bg-white">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-info-subtle text-info p-3 rounded-3 me-3">
                        <i class="bi bi-person-heart fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-medium">Active Doctors</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.ActiveDoctorsCount</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">


        <div class="col-lg-8">


            <div class="card border-0 shadow-sm mb-4 bg-white">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">
                        <i class="bi bi-clock-history text-primary me-2"></i>Live Appointments (Today)
                    </h5>
                    <a asp-controller="Appointment" asp-action="Index" class="btn btn-sm btn-link text-decoration-none fw-semibold">View All</a>
                </div>
                <div class="card-body px-0 pb-0">
                    <div class="table-responsive">
                        <table class="table align-middle table-hover mb-0">
                            <thead class="table-light text-muted small">
                                <tr>
                                    <th class="ps-4">Patient Name</th>
                                    <th>Doctor</th>
                                    <th>Time</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.LiveAppointments.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">No appointments scheduled for today.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var appointment in Model.LiveAppointments)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold text-dark">@(appointment.Patient?.Name ?? "N/A")</td>
                                            <td class="text-muted">@(appointment.Doctor?.Name ?? "N/A")</td>
                                            <td>@appointment.AppointmentDate.ToString("hh:mm tt")</td>
                                            <td>
                                                @if (appointment.Status.ToString() == "Completed")
                                                {
                                                    <span class="badge bg-success-subtle text-success px-2 py-1">Completed</span>
                                                }
                                                else if (appointment.Status.ToString() == "Canceled")
                                                {
                                                    <span class="badge bg-danger-subtle text-danger px-2 py-1">Canceled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning-subtle text-warning px-2 py-1">@appointment.Status</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-controller="Appointment" asp-action="Update" asp-route-id="@appointment.Id" class="btn btn-sm btn-outline-primary py-0 px-2 fw-medium">Manage</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>


            <div class="card border-0 shadow-sm bg-white">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">
                        <i class="bi bi-file-earmark-medical text-success me-2"></i>Recent Lab Tests
                    </h5>
                    <a asp-controller="LabTest" asp-action="Index" class="btn btn-sm btn-link text-decoration-none fw-semibold">View All</a>
                </div>
                <div class="card-body px-0 pb-0">
                    <div class="table-responsive">
                        <table class="table align-middle table-hover mb-0">
                            <thead class="table-light text-muted small">
                                <tr>
                                    <th class="ps-4">Patient Name</th>
                                    <th>Test Name</th>
                                    <th>Date</th>
                                    <th class="text-end pe-4">Lab Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.RecentLabTests.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">No lab tests requested recently.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var test in Model.RecentLabTests)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold text-dark">@(test.Patient?.Name ?? "N/A")</td>
                                            <td class="text-muted">@test.TestName</td>
                                            <td>@test.TestDate.ToString("yyyy-MM-dd")</td>
                                            <td class="text-end pe-4 text-secondary">@(string.IsNullOrEmpty(test.LabName) ? "Not Assigned" : test.LabName)</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>


        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-4 bg-white">
                <div class="card-header bg-white border-0 pt-3 pb-2">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h5>
                </div>
                <div class="card-body pt-0">
                    <div class="d-grid gap-2">
                        <a asp-controller="Appointment" asp-action="Create" class="btn btn-outline-primary text-start fw-semibold py-2">
                            <i class="bi bi-calendar-plus me-2"></i> Book New Appointment
                        </a>
                        <a asp-controller="Patient" asp-action="Create" class="btn btn-outline-success text-start fw-semibold py-2">
                            <i class="bi bi-person-plus me-2"></i> Add New Patient
                        </a>
                    </div>
                </div>
            </div>


            <div class="card border-0 shadow-sm bg-white">
                <div class="card-header bg-white border-0 pt-3 pb-2">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-pie-chart text-info me-2"></i>Visits Overview</h5>
                </div>
                <div class="card-body pt-0">
                    <p class="text-muted small mb-3">Quick breakdown of appointment statuses for today.</p>

                 
                    <div class="mb-3">
                        <div class="d-flex justify-content-between text-dark small mb-1 fw-medium">
                            <span>Completed Visits</span>
                            <span>@Model.CompletedPercentage%</span>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @Model.CompletedPercentage%"></div>
                        </div>
                    </div>

                 
                    <div class="mb-3">
                        <div class="d-flex justify-content-between text-dark small mb-1 fw-medium">
                            <span>Scheduled/Pending</span>
                            <span>@Model.PendingPercentage%</span>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-warning" role="progressbar" style="width: @Model.PendingPercentage%"></div>
                        </div>
                    </div>

          
                    <div class="mb-0">
                        <div class="d-flex justify-content-between text-dark small mb-1 fw-medium">
                            <span>Canceled Visits</span>
                            <span>@Model.CanceledPercentage%</span>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-danger" role="progressbar" style="width: @Model.CanceledPercentage%"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>
@model UpdateLabTestVM

@{
    ViewData["Title"] = "Update Lab Test";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fas fa-edit me-2"></i> Update Lab Test / Scan</h4>
        </div>
        <div class="card-body">


            <form asp-action="Update" asp-route-id="@Model.Id" asp-route-patientId="@Model.PatientId" asp-route-appointmentId="@Model.AppointmentId" method="post" enctype="multipart/form-data">
              

                <div class="row mb-3 bg-light p-3 rounded">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted">Patient Name</label>
                        <input type="text" class="form-control-plaintext fw-bold text-dark fs-5" value="@Model.PatientName" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted">Assigned Doctor</label>
                        <input type="text" class="form-control-plaintext fw-bold text-dark fs-5" value="@Model.DoctorName" readonly />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TestName" class="form-label fw-bold">Test / Scan Name</label>
                        <input asp-for="TestName" class="form-control" placeholder="e.g. Complete Blood Count (CBC)" />
                        <span asp-validation-for="TestName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="testType" class="form-label fw-bold">Type</label>
                        <select asp-for="testType" class="form-select" asp-items="Html.GetEnumSelectList<TestType>()">
                            <option value="">-- Select Type --</option>
                        </select>
                        <span asp-validation-for="testType" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TestDate" class="form-label fw-bold">Test Date</label>
                        <input asp-for="TestDate" type="date" class="form-control" />
                        <span asp-validation-for="TestDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="LabName" class="form-label fw-bold">Laboratory / Center Name</label>
                        <input asp-for="LabName" class="form-control" placeholder="e.g. Alfa Labs" />
                        <span asp-validation-for="LabName" class="text-danger"></span>
                    </div>
                </div>


                <div class="mb-4">
                    <label class="form-label fw-bold text-primary"><i class="fas fa-paperclip me-1"></i> Existing Attachments</label>
                    <div class="border p-3 rounded bg-light">
                        @if (Model.ExistingAttachments != null && Model.ExistingAttachments.Any())
                        {
                            <div class="row">
                                @foreach (var attachment in Model.ExistingAttachments)
                                {
                                    <div class="col-md-4 mb-2">
                                        <div class="p-2 border rounded bg-white d-flex align-items-center justify-content-between">

                                            <a href="~/MedicalAttachments/@attachment.FileName" target="_blank" class="text-decoration-none text-truncate me-2" title="Click to view">
                                                <i class="far fa-file-pdf text-danger me-2 fs-5"></i>
                                                @System.IO.Path.GetFileName(attachment.FileName)
                                            </a>
                                            <span class="badge bg-secondary">Saved</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0"><i class="fas fa-info-circle me-1"></i> No attachments uploaded previously.</p>
                        }
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="TestFiles" class="form-label fw-bold"><i class="fas fa-cloud-upload-alt me-1"></i> Upload New Files</label>
                    <input asp-for="TestFiles" type="file" multiple class="form-control" accept=".jpg,.jpeg,.png,.pdf" />
                    <small class="text-muted">Allowed types: JPG, PNG, PDF. Max size per file: 20MB.</small>
                    <span asp-validation-for="TestFiles" class="text-danger"></span>
                </div>

       
                <div class="mb-4">
                    <label asp-for="Summary" class="form-label fw-bold text-danger">Reason for Update / Summary *</label>
                    <textarea asp-for="Summary" class="form-control" rows="3" placeholder="Please provide a brief justification for modifying this test data (Mandatory for Audit Logs)..."></textarea>
                    <span asp-validation-for="Summary" class="text-danger"></span>
                </div>

        
                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-success px-5">
                        <i class="fas fa-save me-1"></i> Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model Prescription

@{
    ViewData["Title"] = "Delete Prescription";
}

<h1>Delete Prescription</h1>

<h3>Are you sure you want to delete this?</h3>
<dl class="row">
    <dt class="col-sm-2">Appointment</dt>
    <dd class="col-sm-10">@Model.Appointment?.AppointmentDate</dd>
    <dt class="col-sm-2">Diagnosis</dt>
    <dd class="col-sm-10">@Model.Diagnosis</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

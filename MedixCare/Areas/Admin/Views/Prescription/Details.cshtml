@model Prescription

@{
    ViewData["Title"] = "Prescription Details";
}

<h1>Prescription Details</h1>

<dl class="row">
    <dt class="col-sm-2">Appointment</dt>
    <dd class="col-sm-10">@Model.Appointment?.AppointmentDate</dd>
    <dt class="col-sm-2">Diagnosis</dt>
    <dd class="col-sm-10">@Model.Diagnosis</dd>
    <dt class="col-sm-2">Created At</dt>
    <dd class="col-sm-10">@Model.CreatedAt.ToShortDateString()</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>

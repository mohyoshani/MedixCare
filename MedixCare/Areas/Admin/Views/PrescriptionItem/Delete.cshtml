@model PrescriptionItem

@{
    ViewData["Title"] = "Delete Prescription Item";
}

<h1>Delete Prescription Item</h1>

<h3>Are you sure you want to delete this?</h3>
<dl class="row">
    <dt class="col-sm-2">Prescription</dt>
    <dd class="col-sm-10">@Model.Prescription?.Diagnosis</dd>
    <dt class="col-sm-2">Medicine Name</dt>
    <dd class="col-sm-10">@Model.MedicineName</dd>
    <dt class="col-sm-2">Dosage</dt>
    <dd class="col-sm-10">@Model.Dosage</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@model ApplicationUserFilterVM

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            <i class="bi bi-people-fill text-primary"></i>
            System Users
        </h2>

        <form asp-action="Index" method="get" class="d-flex w-50">
            <div class="input-group">
                <span class="input-group-text bg-primary text-white">
                    <i class="bi bi-search"></i>
                </span>

                <input type="text" name="query" value="@Model.query" class="form-control" placeholder="Search by Name..." />

                <button type="submit" class="btn btn-primary">
                    Filter
                </button>

                @if (!string.IsNullOrEmpty(Model.query))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Clear
                    </a>
                }
            </div>
        </form>

    </div>

 

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Email</th>
                        <th>Name</th>
                        <th class="text-center">Role</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.UserRoles)
                    {
                      
                        <tr>
                            <td class="ps-4">
                                <i class="far fa-envelope text-muted me-2"></i>@item.Key.Email
                            </td>
                            <td class="fw-semibold">@item.Key.UserName</td>

                            <td class="text-center">
                                <span class="badge bg-info text-white px-3 py-2 rounded-pill fw-normal">
                                    @item.Value
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="UpdateRole" asp-route-id="@item.Key.Id" class="btn btn-sm btn-warning fw-semibold">
                                        <i class="fas fa-edit me-1"></i>Role
                                    </a>

                                    <a asp-action="LockUnlock"
                                       asp-route-id="@item.Key.Id"
                                       class="btn btn-sm @(item.Key.LockoutEnabled ? "btn-danger" : "btn-success") fw-semibold">
                                        <i class="fas @(item.Key.LockoutEnabled ? "fa-lock" : "fa-unlock") me-1"></i>
                                        @(item.Key.LockoutEnabled ? "Lock" : "UnLock")
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-12 d-flex justify-content-center">
            <nav>
                <ul class="pagination shadow-sm">
                    @if (Model.currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Admin/User/Index?page=@(Model.currentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    }

                    @for (var i = 1; i <= Model.totalPages; i++)
                    {
                        <li class="page-item @(i == Model.currentPage ? "active" : "")">
                            <a class="page-link" href="/Admin/User/Index?page=@i">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.currentPage != Model.totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Admin/User/Index?page=@(Model.currentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .btn {
        border-radius: 8px;
    }

    .card {
        border-radius: 12px;
    }

    .pagination .page-link {
        border-radius: 6px;
        margin: 0 3px;
    }
</style>
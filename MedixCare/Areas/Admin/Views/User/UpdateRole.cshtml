@model UserWithRoleVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update User Role</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post">
                <div class="mb-3">
                    <label for="UserName" class="form-label">User Name</label>
                    <input class="form-control" placeholder="UserName" asp-for="ApplicationUser.UserName" disabled>
                </div>
                <div class="mb-3">
                    <label for="Role" class="form-label">Role</label>
                    <select name="RoleName" class="form-select" id="Role">
                        @foreach (var item in Model.IdentityRoles)
                        {
                            if (item.Name == Model.RoleName)
                            {
                                <option value="@item.Name" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Name">@item.Name</option>
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial">
    }
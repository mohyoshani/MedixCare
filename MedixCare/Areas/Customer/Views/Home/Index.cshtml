@{
    ViewData["Title"] = "Welcome to MedixCare CMS";
}

<!-- Header Start -->
<div class="container-fluid header bg-primary p-0 mb-5">
    <div class="row g-0 align-items-center flex-column-reverse flex-lg-row">
        <div class="col-lg-6 p-5 wow fadeIn" data-wow-delay="0.1s">
            <h1 class="display-4 text-white mb-5">Advanced Clinical Management System</h1>
            <p class="text-light mb-4 fs-5">Streamline your workflow, from patient registration and dynamic appointment scheduling to comprehensive lab test tracking in one unified dashboard.</p>
            <div class="row g-4 mt-2">
                <div class="col-sm-4">
                    <div class="border-start border-light ps-4">
                        <h2 class="text-white mb-1" data-toggle="counter-up">100</h2>
                        <p class="text-light mb-0">% Data Security</p>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="border-start border-light ps-4">
                        <h2 class="text-white mb-1" data-toggle="counter-up">24</h2>
                        <p class="text-light mb-0">Hour Support</p>
                    </div>
                </div>
            </div>
       
            <a href="/Identity/Account/Login" class="btn btn-light rounded-pill py-3 px-5 mt-5 fw-bold text-primary shadow-sm">
                Access Dashboard <i class="fa fa-arrow-right ms-2"></i>
            </a>
        </div>
        <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
            <div class="owl-carousel header-carousel">
                <div class="owl-carousel-item position-relative">
                    <img class="img-fluid w-100" src="~/img/carousel-1.jpg" alt="">
              
                    <div class="owl-carousel-text glass-panel m-4" style="max-width: 450px; bottom: 20px; position: absolute;">
                        <h3 class="text-primary mb-2"><i class="fas fa-calendar-check me-2"></i>Smart Scheduling</h3>
                        <p class="mb-0 text-dark">Manage doctor schedules and track daily patient visits seamlessly with our dynamic booking engine.</p>
                    </div>
                </div>
                <div class="owl-carousel-item position-relative">
                    <img class="img-fluid w-100" src="~/img/carousel-2.jpg" alt="">
                    <div class="owl-carousel-text glass-panel m-4" style="max-width: 450px; bottom: 20px; position: absolute;">
                        <h3 class="text-primary mb-2"><i class="fas fa-flask me-2"></i>Lab Integration</h3>
                        <p class="mb-0 text-dark">Track pending and completed lab tests directly from the physician's unified dashboard.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Header End -->
<!-- System Modules Start -->
<div id="features" class="container-xxl py-5">
    <div class="container">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
            <p class="d-inline-block border rounded-pill py-1 px-4">Core Modules</p>
            <h1>System Capabilities</h1>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="service-item bg-light rounded h-100 p-5 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle mb-4 shadow-sm" style="width: 75px; height: 75px;">
                        <i class="fa fa-users text-primary fs-3"></i>
                    </div>
                    <h4 class="mb-3">Patient Management</h4>
                    <p class="mb-4">Maintain comprehensive medical records, histories, and visit logs in a secure, centralized SQL database.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="service-item bg-light rounded h-100 p-5 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle mb-4 shadow-sm" style="width: 75px; height: 75px;">
                        <i class="fa fa-calendar-alt text-primary fs-3"></i>
                    </div>
                    <h4 class="mb-3">Advanced Scheduling</h4>
                    <p class="mb-4">Efficiently allocate time slots, prevent double-booking, and manage staff availability in real-time.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="service-item bg-light rounded h-100 p-5 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle mb-4 shadow-sm" style="width: 75px; height: 75px;">
                        <i class="fa fa-vials text-primary fs-3"></i>
                    </div>
                    <h4 class="mb-3">Laboratory Tracking</h4>
                    <p class="mb-4">Seamlessly connect consultations with lab requests. Monitor tests and fetch results directly to the profile.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- System Modules End -->
<!-- Tech Support Start -->
<div id="support" class="container-xxl py-5 mt-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                <p class="d-inline-block border rounded-pill py-1 px-4">IT Helpdesk</p>
                <h1 class="mb-4">Need Technical Assistance?</h1>
                <p class="mb-4">If you are experiencing issues accessing your dashboard, forgot your credentials, or need administrative assistance, please submit a ticket or contact our 24/7 IT helpdesk.</p>
                <div class="bg-light rounded d-flex align-items-center p-4 mb-4">
                    <div class="d-flex flex-shrink-0 align-items-center justify-content-center rounded-circle bg-white shadow-sm" style="width: 55px; height: 55px;">
                        <i class="fa fa-phone-alt text-primary"></i>
                    </div>
                    <div class="ms-4">
                        <p class="mb-2">Call Helpdesk</p>
                        <h5 class="mb-0">+20 123 456 7890</h5>
                    </div>
                </div>
                <div class="bg-light rounded d-flex align-items-center p-4">
                    <div class="d-flex flex-shrink-0 align-items-center justify-content-center rounded-circle bg-white shadow-sm" style="width: 55px; height: 55px;">
                        <i class="fa fa-envelope-open text-primary"></i>
                    </div>
                    <div class="ms-4">
                        <p class="mb-2">Email Support</p>
                        <h5 class="mb-0">support@MedixCare.com</h5>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="bg-light rounded h-100 d-flex align-items-center p-5">
                    <form style="width: 100%;">
                        <div class="row g-3">
                            <div class="col-12 col-sm-6">
                                <input type="text" class="form-control border-0 bg-white" placeholder="Staff ID / Username" style="height: 55px;">
                            </div>
                            <div class="col-12 col-sm-6">
                                <input type="email" class="form-control border-0 bg-white" placeholder="Work Email" style="height: 55px;">
                            </div>
                            <div class="col-12">
                                <select class="form-select border-0 bg-white" style="height: 55px;">
                                    <option selected>Select Issue Category</option>
                                    <option value="1">Login / Password Reset</option>
                                    <option value="2">System Error / Bug</option>
                                    <option value="3">Permissions Request</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <textarea class="form-control border-0 bg-white" rows="5" placeholder="Describe your technical issue..."></textarea>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-gradient w-100 py-3" type="button">Submit Ticket</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Tech Support End -->
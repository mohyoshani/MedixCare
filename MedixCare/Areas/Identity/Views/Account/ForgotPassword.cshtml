@model ForgotPasswordVM


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-4 p-sm-5 text-center">

                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 80px; height: 80px;">
                            <i class="bi bi-shield-lock text-warning" style="font-size: 2rem;"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-3">Forgot Password?</h2>
                    <p class="text-muted mb-4">
                        No worries! Enter your email address and we will send you a link to reset your password.
                    </p>

                    <form asp-action="ForgotPassword" method="post" id="forgetPasswordForm" asp-controller="Account" asp-area="Identity">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3 text-start">

                            <input asp-for="UserNameOrEmail" class="form-control" placeholder="name@example.com" id="emailInput" />
                            <label asp-for="UserNameOrEmail">Email Address</label>
                            <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>
                        </div>

                        <button type="submit" id="btnSubmit" class="btn btn-primary btn-lg w-100 mb-3 shadow-sm">
                            <span id="btnText">Send Reset Link</span>
                            <span id="timerText" class="d-none ms-1">(<span id="seconds">30</span>s)</span>
                        </button>
                    </form>

                    <div class="mt-3">
                        <p class="small text-muted">
                            Remembered your password? <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Sign In</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@model LoginVM
<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header"><h3 class="text-center font-weight-light my-4">Login</h3></div>
                <div class="card-body">
                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="UserNameOrEmail" class="form-control" id="inputEmail" type="email" placeholder="name@example.com or UserName" />
                            <label asp-for="UserNameOrEmail" > User Name or Email address</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control" id="inputPassword" type="password" placeholder="Password" />
                            <label asp-for="Password" for="inputPassword">Password</label>
                        </div>
                        <div class="form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" id="inputRememberPassword" type="checkbox" />
                            <label asp-for="RememberMe" class="form-check-label" for="inputRememberPassword">Remember Password</label>
                        </div>
                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                            <a class="small" href="~/Identity/Account/ForgotPassword">Forgot Password?</a>
                            <a class="btn btn-primary" href="~/Customer/Home/Index">Login</a>
                            
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a href="~/Identity/Account/Register">Need an account? Sign up!</a></div>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a href="~/Identity/Account/ResendConfirmationEmail">Resend Email Confirmation</a></div>
                </div>
            </div>
        </div>
    </div>
</div>
@model ResendEmailConfirmationVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-4 p-sm-5 text-center">

                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 80px; height: 80px;">
                            <i class="bi bi-envelope-at text-primary" style="font-size: 2rem;"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold mb-3">Didn't get the email?</h2>
                    <p class="text-muted mb-4">
                        Enter your email below and we'll send you a new confirmation link to activate your account.
                    </p>

                    <form asp-action="ResendConfirmationEmail" method="post" asp-area="Identity" asp-controller="Account">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3 text-start">
                            <input asp-for="EmailOrUserName" class="form-control" placeholder="name@example.com" />
                            <label asp-for="EmailOrUserName">Email Address</label>
                            <span asp-validation-for="EmailOrUserName" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3 shadow-sm">
                            Resend Confirmation
                        </button>
                    </form>

                    <div class="mt-3">
                        <p class="small text-muted">
                            Remembered your password? <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Sign In</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
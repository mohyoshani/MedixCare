@model ResetPasswordVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-4 p-sm-5">

                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-key text-primary" style="font-size: 2.5rem;"></i>
                        </div>
                        <h2 class="fw-bold">New Password</h2>
                        <p class="text-muted small">Please enter your new password to regain access to your account.</p>
                    </div>

                    <form asp-action="ResetPassword" method="post" id="resetForm" asp-controller="Account" asp-area="Identity">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                      

                        <div class="form-floating mb-3 text-start">
                            <input asp-for="Password" class="form-control" placeholder="New Password" id="passInput" />
                            <label asp-for="Password">New Password</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4 text-start">
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password" />
                            <label asp-for="ConfirmPassword">Confirm Password</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" id="btnSubmit" class="btn btn-primary btn-lg w-100 shadow-sm">
                            <span id="btnText">Reset Password</span>

                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>